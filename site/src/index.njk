---
layout: base.njk
---

<header class="hero">
  <div class="hero-inner">
    <h1 class="hero-title">{{ site.missionary }}</h1>
    <p class="hero-mission">{{ site.mission }}</p>
    <p class="hero-subtitle">お帰りなさい</p>
    <p class="hero-dates">{{ site.missionStart }} – {{ site.missionEnd }}</p>
  </div>
</header>

<main>
  {# Mission President #}
  <section class="section" id="president">
    <div class="mission-president">
      <img src="/assets/images/mission-president.png" alt="President and Sister Sano" class="president-photo">
      <div class="president-bio">
        <h3>{{ site.missionPresident }} & {{ site.missionPresidentWife }}</h3>
        <p>President Sano is a former mission presidency counselor, temple ordinance worker, district president, branch president, branch mission leader, elders quorum president, and missionary in the Japan Kobe Mission. He was born in Kagoshima City, Japan.</p>
        <p>Sister Sano is a former branch Relief Society presidency counselor, temple ordinance worker, district Young Women president, branch Primary president, Sunday School teacher, institute teacher, seminary teacher, and missionary in the Japan Okayama Mission. She was born in Omuta City, Japan.</p>
      </div>
    </div>
  </section>

  {# Map Section #}
  <section class="section section-wide" id="map">
    <h2 class="section-title">地図 <span>My Mission Map</span></h2>
    <div class="map-container">
      <div id="missionMap"></div>
      <div class="map-mtc-inset">
        <div class="mtc-top">
          <span class="mtc-number">1</span>
          <span class="mtc-label">MTC — Provo, Utah</span>
        </div>
        <span class="mtc-dates">Jul – Sep 2024</span>
      </div>
    </div>
    <div class="mission-map-official" onclick="openModal('/assets/images/mission-map-1.png')">
      <div class="map-official-label">
        <span class="map-label-text">Official Kobe Japan Mission Boundaries</span>
        <span class="map-label-hint">Click to enlarge</span>
      </div>
      <img src="/assets/images/mission-map-1.png" alt="Kobe Japan Mission Map" loading="lazy">
    </div>
  </section>

  {# Timeline Section #}
  <section class="section" id="timeline">
    <h2 class="section-title">旅 <span>My Journey</span></h2>
    <div class="timeline">
      {% set areas = [
        { "name": "MTC — Provo, Utah", "dates": "Jul 8 – Sep 11, 2024", "companions": ["Elder Wheeler"], "notes": ["Cow Stuffed Animal"] },
        { "name": "Ibaraki, Osaka", "dates": "Sep 12 – Dec 9, 2024", "companions": ["Elder Sonomura"], "notes": ["That's true."] },
        { "name": "Marugame, Shikoku", "dates": "Dec 9, 2024 – Mar 1, 2025", "companions": ["Elder MacKay", "Elder Martinson"], "notes": ["Ace, Ace", "Wampaku"] },
        { "name": "Izumi Tottori, Sennan", "dates": "Mar 1 – Jul 5, 2025", "companions": ["Elder Magbago", "Elder Sofoul"], "notes": ["Card Games", "High Cleanliness Standards"] },
        { "name": "Tsuyama, Okayama", "dates": "Jul 5 – Dec 21, 2025", "companions": ["Elder Nakazawa", "Elder Lear"], "notes": ["Diabolo Wizard", "Say..."] },
        { "name": "Gobo, Wakayama", "dates": "Dec 21, 2025 – Mar 14, 2026", "companions": ["Elder Warnick", "Elder Childs"], "notes": ["Bruno Mars", "Backflip"] },
        { "name": "Nishiwaki, Hyogo", "dates": "Mar 14 – Jun 4, 2026", "companions": ["Elder Talbot", "Elder Gifford"], "notes": ["Stretching", "Rich"] }
      ] %}
      {% for area in areas %}
      <div class="timeline-item{% if loop.index == 1 %} timeline-item-full{% endif %}">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <h3><span class="area-number">{{ loop.index }}</span>{{ area.name }}</h3>
          <p class="timeline-dates">{{ area.dates }}</p>
          <div class="timeline-companions">
            {% for i in range(0, area.companions.length) %}
            <p class="timeline-companion">{{ area.companions[i] }} <span class="companion-note-inline">({{ area.notes[i] }})</span></p>
            {% endfor %}
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  </section>

  {# Companions Section #}
  <section class="section" id="companions">
    <h2 class="section-title">仲間 <span>My Companions</span></h2>
    <div class="companions-grid">
      {% for companion in companions %}
      <div class="companion-card">
        <h3>{{ companion.name }}</h3>
        <p>{{ companion.area }}</p>
        <p class="companion-dates">{{ companion.dates }}</p>
        {% if companion.note %}<p class="companion-note">{{ companion.note }}</p>{% endif %}
      </div>
      {% endfor %}
    </div>
  </section>

  {# Art Section #}
  <section class="section" id="art">
    <h2 class="section-title">芸術 <span>My Art</span></h2>
    <p class="section-intro art-intro">「Throughout my mission, I used my gift for art to touch lives — drawing for members, friends, and investigators, sharing the gospel through creativity.」</p>
    <div class="art-carousel">
      <div class="carousel-inner">
        {% for piece in imageInventory %}{% if piece.art and piece.visible !== false %}
        <div class="carousel-slide" data-caption="{{ piece.caption | default('') }}" data-rawdesc="{{ piece.rawDescription | default('') }}">
          <img src="/assets/images/{{ piece.source }}/{{ piece.modal }}" alt="{{ piece.caption }}" loading="lazy" onclick="openModal(this.src, this.parentElement.dataset.caption, this.parentElement.dataset.rawdesc); return false;">
        </div>
        {% endif %}{% endfor %}
      </div>
      <button class="carousel-control prev" onclick="carouselPrev()" aria-label="Previous">‹</button>
      <button class="carousel-control next" onclick="carouselNext()" aria-label="Next">›</button>
      <div class="carousel-indicators">
        {% for piece in imageInventory %}{% if piece.art and piece.visible !== false %}
        <button class="indicator" onclick="carouselGoTo(this)" aria-label="Slide"></button>
        {% endif %}{% endfor %}
      </div>
    </div>
  </section>

  {# Memories Section #}
  <section class="section section-wide" id="photos">
    <h2 class="section-title">思い出 <span>My Memories</span></h2>
    <div class="photo-filters">
      <div class="filter-tags">
        <button class="filter-btn active" data-tag="all" onclick="setPhotoTag(this, 'all')">All</button>
        <button class="filter-btn" data-tag="people" onclick="setPhotoTag(this, 'people')">People</button>
        <button class="filter-btn" data-tag="group" onclick="setPhotoTag(this, 'group')">Group</button>
        <button class="filter-btn" data-tag="scenery" onclick="setPhotoTag(this, 'scenery')">Scenery</button>
        <button class="filter-btn" data-tag="food" onclick="setPhotoTag(this, 'food')">Food</button>
        <button class="filter-btn" data-tag="temple" onclick="setPhotoTag(this, 'temple')">Temple</button>
        <button class="filter-btn" data-tag="art" onclick="setPhotoTag(this, 'art')">Art</button>
        <button class="filter-btn" data-tag="video" onclick="setPhotoTag(this, 'video')">Video</button>
      </div>
      <div class="filter-controls">
        <input type="text" id="photoSearch" class="chat-search" placeholder="Search..." oninput="filterPhotos()">
        <input type="date" id="photoFrom" class="chat-date-input" onchange="filterPhotos()">
        <input type="date" id="photoTo" class="chat-date-input" onchange="filterPhotos()">
      </div>
    </div>
    <div class="photo-grid" id="photoGrid">
      {% for img in imageInventory %}{% if img.visible !== false %}
      <div class="photo-item{% if img.video %} video-item{% endif %}" data-tags="{{ img.tags | join(',') }}{% if img.video %},video{% endif %}" data-featured="{{ img.featured }}" data-date="{{ img.date }}" data-desc="{{ img.rawDescription | default('') | lower }}" data-caption="{{ img.caption | default('') }}" data-rawdesc="{{ img.rawDescription | default('') }}"{% if img.video %} data-video="/assets/videos/{{ img.video }}"{% endif %}>
        <img src="/assets/images/{{ img.source }}/{{ img.thumb }}" alt="{{ img.caption }}" loading="lazy" onclick="{% if img.video %}openVideoModal('/assets/videos/{{ img.video }}', this.parentElement.dataset.caption, this.parentElement.dataset.rawdesc){% else %}openModal('/assets/images/{{ img.source }}/{{ img.modal }}', this.parentElement.dataset.caption, this.parentElement.dataset.rawdesc){% endif %}; return false;">
        {% if img.video %}<span class="video-badge">▶</span>{% endif %}
        {% if img.caption %}<span class="photo-caption">{{ img.caption }}</span>{% endif %}
      </div>
      {% endif %}{% endfor %}
    </div>
    <div class="photo-paging">
      <button onclick="photoPrev()" id="photoPrev">← Prev</button>
      <span id="photoPageInfo"></span>
      <button onclick="photoNext()" id="photoNext">Next →</button>
    </div>
  </section>

  {# Quotes Section #}
  <section class="section" id="quotes">
    <h2 class="section-title">言葉 <span>My Quotes</span></h2>
    <div class="quotes-carousel">
      {% for quote in quotes %}
      <blockquote class="quote-slide">
        <p>{{ quote.text }}</p>
        <cite>— {{ quote.date }}{% if quote.source %}, {{ quote.source }}{% endif %}</cite>
      </blockquote>
      {% endfor %}
      <button class="carousel-control prev" onclick="quotePrev()" aria-label="Previous">‹</button>
      <button class="carousel-control next" onclick="quoteNext()" aria-label="Next">›</button>
    </div>
  </section>

  {# Emails Section #}
  <section class="section" id="emails">
    <h2 class="section-title">手紙 <span>My Letters Home</span></h2>
    <div class="email-filters">
      <input type="text" id="emailSearch" class="chat-search" placeholder="Search..." oninput="filterEmails()">
      <input type="date" id="emailFrom" class="chat-date-input" onchange="filterEmails()">
      <input type="date" id="emailTo" class="chat-date-input" onchange="filterEmails()">
      <button class="filter-btn" id="emailAudioBtn" onclick="this.classList.toggle('active'); filterEmails()">Audio</button>
      <button class="filter-btn" id="emailPhotosBtn" onclick="this.classList.toggle('active'); filterEmails()">Photos</button>
    </div>
    <div class="emails-list">
      {% for email in emails %}
      <details class="email-entry" data-date="{{ email.date }}" data-has-audio="{% if email.audio %}1{% endif %}" data-has-photos="{% if email.images.length %}1{% endif %}">
        <summary>
          <span class="email-date">{{ email.date }}</span>
          <span class="email-subject">{{ email.subject }}</span>
          {% if email.audio %}<span class="email-audio-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg></span>{% endif %}
          {% if email.images.length %}<span class="email-img-count"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg> {{ email.images.length }}</span>{% endif %}
        </summary>
        <div class="email-body">
          {% if email.summary %}<p class="email-summary">{{ email.summary }}</p>{% endif %}
          {% if email.audio %}
          <div class="email-audio">
            <audio controls preload="none" src="/assets/audio/{{ email.audio }}"></audio>
            {% if audioTranscripts[email.audio] %}
            <details class="audio-transcript">
              <summary>Show transcript</summary>
              <p>{{ audioTranscripts[email.audio].text }}</p>
            </details>
            {% endif %}
          </div>
          {% endif %}
          {{ email.body | safe }}
          {% if email.images.length %}
          <div class="email-images">
            {% for img in email.images %}
            {% set base = img | replace(".jpg", "") | replace(".jpeg", "") | replace(".png", "") | replace(".webp", "") %}
            <a href="/assets/images/emails/{{ base }}-modal.jpg" class="email-thumb" onclick="var m=imgMeta[this.getAttribute('href')]||{}; openModal(this.href, m.c, m.d); return false;">
              <img src="/assets/images/emails/{{ base }}-thumb.jpg" alt="Photo" loading="lazy">
            </a>
            {% endfor %}
          </div>
          {% endif %}
        </div>
      </details>
      {% endfor %}
    </div>
  </section>

  {# Messages Section #}
  <section class="section" id="messages">
    <h2 class="section-title">会話 <span>Messages Home</span></h2>
    <div class="chat-filters">
      <input type="text" id="chatSearch" class="chat-search" placeholder="Search..." oninput="filterChat()">
      <input type="date" id="chatFrom" class="chat-date-input" onchange="filterChat()">
      <input type="date" id="chatTo" class="chat-date-input" onchange="filterChat()">
      <button class="filter-btn" id="chatPhotosBtn" onclick="this.classList.toggle('active'); filterChat()">Photos</button>
      <button class="filter-btn" id="chatAudioBtn" onclick="this.classList.toggle('active'); filterChat()">Audio</button>
    </div>
    <div class="chat-thread">
      {% for item in messengerHighlights %}
        {% if item.type == 'gap' %}
          <div class="chat-gap">⋯</div>
        {% elif item.type == 'date' %}
          <div class="chat-date" data-date="{{ item.date }}">{{ item.date }}</div>
        {% elif item.type == 'message' %}
          <div class="chat-bubble {% if item.isKaden %}kaden{% else %}other{% endif %}" data-has-photo="{% if item.photos %}1{% endif %}" data-has-audio="{% if item.audio %}1{% endif %}">
            {% if not item.isKaden %}<span class="chat-sender">{{ item.sender }}</span>{% endif %}
            {% if item.text %}<p>{{ item.text }}</p>{% endif %}
            {% if item.photos %}
            <div class="chat-photos">{% for p in item.photos %}<img src="/assets/images/messenger/{{ p }}" alt="Photo" loading="lazy" onclick="openModal('/assets/images/messenger/{{ p }}'); return false;">{% endfor %}</div>
            {% endif %}
            {% if item.audio %}
            <div class="chat-audio">{% for a in item.audio %}<audio controls preload="none" src="/assets/audio/{{ a }}"></audio>{% endfor %}</div>
            {% endif %}
            {% if item.reactions %}<span class="chat-reactions">{% for r in item.reactions %}{{ r.emoji }}{% endfor %}</span>{% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
    <button class="chat-expand-btn" onclick="this.previousElementSibling.classList.toggle('expanded'); this.textContent = this.textContent === 'Show All' ? 'Collapse' : 'Show All';">Show All</button>
  </section>

<footer class="site-footer">
  <p>Made with love for your homecoming — June 2026</p>
  <p class="footer-id">010</p>
</footer>
